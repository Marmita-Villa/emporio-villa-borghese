# ──────────────────────────────────────────────
# CONFIGURAÇÕES DO WHATSAPP (Meta for Developers)
# ──────────────────────────────────────────────

# Token de acesso permanente gerado no Meta Business
WHATSAPP_TOKEN=seu_token_aqui

# ID do número de telefone do WhatsApp Business
# Encontrado em: Meta for Developers > seu app > WhatsApp > Configuração
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id_aqui

# Token de verificação do webhook (você cria — qualquer string)
WHATSAPP_VERIFY_TOKEN=minha_mercearia_bot_2024

# App Secret do app na Meta (Configurações > Básico). OPCIONAL, mas recomendado:
# se definido, o webhook passa a validar a assinatura X-Hub-Signature-256 e
# rejeita requisições que não vierem da Meta. Sem ele, aceita como antes.
META_APP_SECRET=

# ──────────────────────────────────────────────
# CONFIGURAÇÕES DA IA (Anthropic)
# ──────────────────────────────────────────────

# Chave da API da Anthropic
# Crie em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# CONFIGURAÇÕES DO SEU SISTEMA INTERNO
# ──────────────────────────────────────────────

# URL base da API do Empório Villa Borghese (sem barra no final)
SISTEMA_API_URL=https://api.emporiovillaborghese.com.br

# Token Bearer de autenticação da API
# Token de homologação (testes): PgnSIc82Rh0RQcZfoPQ1Zfoje21
# Em produção, use o token oficial configurado no painel
SISTEMA_API_TOKEN=PgnSIc82Rh0RQcZfoPQ1Zfoje21

# ──────────────────────────────────────────────
# BANCO DE DADOS
# ──────────────────────────────────────────────

# Upstash Redis — sessões persistentes
# Crie em: https://upstash.com
UPSTASH_REDIS_URL=https://seu-banco.upstash.io
UPSTASH_REDIS_TOKEN=seu_token_aqui

# Supabase — histórico de conversas e pedidos
# Crie em: https://supabase.com
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui

# ──────────────────────────────────────────────
# SEGURANÇA / PAINEL
# ──────────────────────────────────────────────

# OBRIGATÓRIO: segredo usado para assinar os tokens de login do painel de atendimento.
# Use uma string longa e aleatória. SEM esta variável o painel fica desativado
# (o bot do WhatsApp continua funcionando normalmente).
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria

# Chave de acesso ao dashboard gerencial (/dashboard).
DASHBOARD_KEY=defina_uma_senha_forte

# ──────────────────────────────────────────────
# HIPCOM (produtos, estoque, clientes)
# ──────────────────────────────────────────────
HIPCOM_URL=http://emporiovilla.dyndns.info:2222/api/hipcom
HIPCOM_USER=hipcomfull
HIPCOM_PASS=
HIPCOM_CNPJ=
HIPCOM_SENHA=
HIPCOM_CLIENT_STORE=1
HIPCOM_PRICE_STORE=6
HIPCOM_STOCK_STORES=1,6
HIPCOM_BLOCKED_ITEMS=

# ── Frequência das chamadas ao Hipcom (protege o servidor local) ──
# Intervalo do sync de clientes, em horas (padrão 6). Aumente para aliviar o servidor.
HIPCOM_SYNC_INTERVAL_H=6
# Tempo de cache (minutos) — quanto maior, menos chamadas ao Hipcom:
ESTOQUE_CACHE_MIN=5     # estoque (curto: precisa ser fresco)
PRODUTOS_CACHE_MIN=15   # busca de produtos
OFERTAS_CACHE_MIN=30    # ofertas do dia

# ──────────────────────────────────────────────
# SERVIDOR
# ──────────────────────────────────────────────
PORT=3000

# Seleção da API de retaguarda: legacy (padrão) ou v1
# API_VERSION=legacy

# Modo mock (testes sem sistema real): true para ativar
# MOCK_MODE=false
