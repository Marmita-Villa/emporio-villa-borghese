# ──────────────────────────────────────────────
# CONFIGURAÇÕES DO WHATSAPP (Meta for Developers)
# ──────────────────────────────────────────────

# Token de acesso permanente gerado no Meta Business
WHATSAPP_TOKEN=seu_token_aqui

# ID do número de telefone do WhatsApp Business
# Encontrado em: Meta for Developers > seu app > WhatsApp > Configuração
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id_aqui

# Token de verificação do webhook (você cria — qualquer string)
WHATSAPP_VERIFY_TOKEN=minha_mercearia_bot_2024

# ──────────────────────────────────────────────
# CONFIGURAÇÕES DA IA (Anthropic)
# ──────────────────────────────────────────────

# Chave da API da Anthropic
# Crie em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# CONFIGURAÇÕES DO SEU SISTEMA INTERNO
# ──────────────────────────────────────────────

# URL base da API do Empório Villa Borghese (sem barra no final)
SISTEMA_API_URL=https://api.emporiovillaborghese.com.br

# Token Bearer de autenticação da API
# Token de homologação (testes): PgnSIc82Rh0RQcZfoPQ1Zfoje21
# Em produção, use o token oficial configurado no painel
SISTEMA_API_TOKEN=PgnSIc82Rh0RQcZfoPQ1Zfoje21

# ──────────────────────────────────────────────
# BANCO DE DADOS
# ──────────────────────────────────────────────

# Upstash Redis — sessões persistentes
# Crie em: https://upstash.com
UPSTASH_REDIS_URL=https://seu-banco.upstash.io
UPSTASH_REDIS_TOKEN=seu_token_aqui

# Supabase — histórico de conversas e pedidos
# Crie em: https://supabase.com
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui

# ──────────────────────────────────────────────
# SERVIDOR
# ──────────────────────────────────────────────
PORT=3000
